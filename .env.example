# ============================================================
# Nemo Water Risk — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostGIS) ---
# Requires a PostgreSQL DB with the PostGIS extension enabled:
#   CREATE EXTENSION postgis;
DATABASE_URL=postgis://nemo:nemo@localhost:5432/nemo_waterrisk

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LLM (Anthropic) ---
# Model is REQUIRED and read from env — no hardcoded model strings.
ANTHROPIC_API_KEY=
NEMO_LLM_MODEL=claude-sonnet-5
NEMO_LLM_TIMEOUT_MS=45000
NEMO_LLM_MAX_TOKENS=2000
NEMO_LLM_MAX_RESPONSE_CHARS=20000

# --- Siting engine (data-center "where to build" product) ---
# Optional weight override for the suitability composite (need not sum to 1).
# Default: power:0.40,water:0.35,hazard:0.25  (power = #1 constraint today).
NEMO_SITING_WEIGHTS=
# Metro-suitability move (points) that records a SitingChange (default 3.0).
NEMO_SITING_CHANGE_THRESHOLD=
# Live external data for siting (USDM drought overlay + FEMA NRI context).
# On by default; set to 0 to use structural snapshots only (offline/testing).
NEMO_SITING_LIVE=1
# Max fraction of water headroom removed at maximum drought (default 0.5).
NEMO_WATER_DROUGHT_PENALTY=

# --- Monitoring & alerts (recurring-revenue product) ---
# Adverse point-move within a band that triggers an alert, per tier.
# Defaults: basic 7.0, pro 3.0. A band/grade crossing always alerts.
NEMO_ALERT_DELTA_BASIC=
NEMO_ALERT_DELTA_PRO=
# Absolute base URL used for links in alert/report emails (no trailing slash).
PUBLIC_BASE_URL=https://www.nemowaterrisk.com

# --- Agent execution safety ---
# All agent file writes are jailed inside this directory. Absolute path.
NEMO_WORKSPACE_ROOT=./workspace
NEMO_MAX_CONCURRENCY=2

# --- External data sources (public APIs; keys optional/where required) ---
USGS_BASE_URL=https://waterservices.usgs.gov/nwis
NOAA_TOKEN=                 # https://www.ncdc.noaa.gov/cdo-web/token
EPA_BASE_URL=https://data.epa.gov/efservice

# --- Email (report delivery) ---
# Default (unset) = console backend: reports print to the logs. To send real
# email, uncomment and fill these (Gmail example shown; app password required).
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Nemo Water Risk <reports@yourdomain.com>
# Shared secret guarding the inbound-email webhook (see docs/INBOUND_EMAIL.md).
# Append ?token=<this> to the SendGrid Inbound Parse destination URL.
INBOUND_EMAIL_TOKEN=

# --- Marketing / distribution (leave blank until ready to post) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
YOUTUBE_API_KEY=
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
